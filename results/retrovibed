<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" width="1024" height="1024">
  <defs>
    <radialGradient id="eyeGlow" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%" stop-color="#ede9fe" stop-opacity="1"/>
      <stop offset="15%" stop-color="#c4b5fd" stop-opacity="0.9"/>
      <stop offset="35%" stop-color="#a78bfa" stop-opacity="0.7"/>
      <stop offset="55%" stop-color="#7c3aed" stop-opacity="0.4"/>
      <stop offset="75%" stop-color="#5b21b6" stop-opacity="0.2"/>
      <stop offset="100%" stop-color="#4c1d95" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="faceGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#3d3a6e"/>
      <stop offset="100%" stop-color="#2a2750"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="eyeBloom">
      <feGaussianBlur stdDeviation="16" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Face with inset padding for dock sizing -->
  <rect x="72" y="72" width="880" height="880" rx="196" fill="url(#faceGrad)"/>
  <rect x="78" y="78" width="868" height="868" rx="192" fill="none" stroke="#5a4f8a" stroke-width="1.5"/>

  <!-- Visor line -->
  <rect x="200" y="310" width="624" height="5" rx="2.5" fill="#4e4880" opacity="0.5"/>

  <!-- Left eye socket -->
  <circle cx="390" cy="440" r="116" fill="#121028" stroke="#5a4f8a" stroke-width="1.5"/>
  <!-- Left eye glow -->
  <g filter="url(#eyeBloom)">
    <circle cx="390" cy="440" r="100" fill="url(#eyeGlow)" opacity="0.8"/>
    <circle cx="390" cy="440" r="80" fill="none" stroke="#6d28d9" stroke-width="2.5" opacity="0.55"/>
    <circle cx="390" cy="440" r="62" fill="none" stroke="#7c3aed" stroke-width="3" opacity="0.7"/>
    <circle cx="390" cy="440" r="44" fill="none" stroke="#a78bfa" stroke-width="3.5" opacity="0.8"/>
    <circle cx="390" cy="440" r="20" fill="#ddd6fe"/>
  </g>

  <!-- Right eye socket -->
  <circle cx="634" cy="440" r="116" fill="#121028" stroke="#5a4f8a" stroke-width="1.5"/>
  <!-- Right eye glow -->
  <g filter="url(#eyeBloom)">
    <circle cx="634" cy="440" r="100" fill="url(#eyeGlow)" opacity="0.8"/>
    <circle cx="634" cy="440" r="80" fill="none" stroke="#6d28d9" stroke-width="2.5" opacity="0.55"/>
    <circle cx="634" cy="440" r="62" fill="none" stroke="#7c3aed" stroke-width="3" opacity="0.7"/>
    <circle cx="634" cy="440" r="44" fill="none" stroke="#a78bfa" stroke-width="3.5" opacity="0.8"/>
    <circle cx="634" cy="440" r="20" fill="#ddd6fe"/>
  </g>

  <!-- Handlebar mustache -->
  <path d="M 300,670
           C 314,642 342,642 370,678
           C 398,714 418,706 446,672
           C 470,644 490,648 512,680
           C 534,648 554,644 578,672
           C 606,706 626,714 654,678
           C 682,642 710,642 724,670"
        fill="none"
        stroke="#a78bfa"
        stroke-width="7"
        stroke-linecap="round"
        filter="url(#glow)"
        opacity="0.85"/>

  <!-- Ear bolts -->
  <circle cx="136" cy="440" r="20" fill="#322e5c" stroke="#5a4f8a" stroke-width="1.5"/>
  <circle cx="136" cy="440" r="6" fill="#4e4880"/>
  <circle cx="888" cy="440" r="20" fill="#322e5c" stroke="#5a4f8a" stroke-width="1.5"/>
  <circle cx="888" cy="440" r="6" fill="#4e4880"/>

  <!-- Corner rivets -->
  <g fill="#2a2750" stroke="#5a4f8a" stroke-width="1">
    <circle cx="168" cy="178" r="7"/>
    <circle cx="856" cy="178" r="7"/>
    <circle cx="168" cy="846" r="7"/>
    <circle cx="856" cy="846" r="7"/>
  </g>
</svg>
